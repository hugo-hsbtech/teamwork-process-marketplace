    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/plugins/hsb-teamwork/hooks/teamwork-cost-capture.py\""
          }
        ]
      }
    ]
  }
}
