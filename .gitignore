.idea/

# Local dev: agent symlinks exposed for headless eval runs (not part of the repo;
# the plugin resolves agents itself). The skill symlink under .claude/skills/ is tracked.
.claude/agents/

# Python bytecode (e.g. from the cost-capture hook)
__pycache__/
*.pyc

# Teamwork harness runtime session state (transient per-session pointer; not an artifact)
.teamwork/.sessions/
